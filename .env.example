# WatchAgent environment variables
# Copy this file to .env and adjust as needed.
# No credentials are required — Open-Meteo is keyless.

# SQLite database path (inside container, backed by a Docker named volume)
DATABASE_URL=sqlite:////app/data/weather.db

# How often to poll Open-Meteo (seconds). Open-Meteo updates hourly;
# polling every 10 minutes (600s) ensures we catch updates promptly.
POLL_INTERVAL_SECONDS=600

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
